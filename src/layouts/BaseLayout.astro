---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title = 'Mikey Ennen — Artist & Designer',
  description = 'Woodcut prints and wearable art rooted in Pacific Northwest nature.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = 'https://ennendesign.com';
const canonicalUrl = `${siteUrl}${currentPath}`;
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/og-image.jpg" />

  <!-- Open Graph (Facebook, iMessage, LinkedIn, Slack) -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Mikey Ennen" />

  <!-- Twitter / X card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
</head>
<body>

  <!-- ======== HEADER ======== -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <img src="/signature.png" alt="Mikey Ennen" class="logo-sig" />
      </a>

      <nav class="main-nav" id="mainNav">
        <a href="/shop" class:list={[{ active: currentPath.startsWith('/shop') }]}>Shop</a>
        <a href="/about" class:list={[{ active: currentPath === '/about' }]}>About</a>
        <a href="/process" class:list={[{ active: currentPath === '/process' }]}>Process</a>
        <a href="/faq" class:list={[{ active: currentPath === '/faq' }]}>FAQ</a>
        <a href="/contact" class:list={[{ active: currentPath === '/contact' }]}>Contact</a>
      </nav>

      <a href="/shop" class="cart-btn" aria-label="Cart" id="cartBtn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="cart-count" id="cartCount" style="display:none">0</span>
      </a>

      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
        <span></span><span></span>
      </button>
    </div>
  </header>

  <!-- ======== MAIN ======== -->
  <main>
    <slot />
  </main>

  <!-- ======== FOOTER ======== -->
  <footer class="site-footer section--dark">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-name">Mikey Ennen</span>
        <p>Artist & Designer<br/>Pacific Northwest</p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>Explore</h4>
          <a href="/shop">Shop</a>
          <a href="/about">About</a>
          <a href="/process">Process</a>
          <a href="/faq">FAQ</a>
        </div>
        <div class="footer-col">
          <h4>Connect</h4>
          <a href="/contact">Contact</a>
          <a href="https://instagram.com/mikeyennen" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Mikey Ennen. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- ======== CART DRAWER ======== -->
  <div class="cart-overlay" id="cartOverlay"></div>
  <aside class="cart-drawer" id="cartDrawer">
    <div class="cart-drawer__header">
      <h3>Your Cart <span class="cart-header-count" id="cartHeaderCount"></span></h3>
      <button class="cart-drawer__close" id="cartClose" aria-label="Close cart">✕</button>
    </div>
    <div class="cart-drawer__body" id="cartBody">
      <div class="cart-empty" id="cartEmpty">
        <div class="cart-empty__icon">🛒</div>
        <p>Your cart is empty</p>
        <a href="/shop" class="btn btn--outline" style="font-size:0.72rem;letter-spacing:0.1em;">Browse the Collection</a>
      </div>
      <div class="cart-items" id="cartItems"></div>
      <div class="cart-continue" id="cartContinue" style="display:none">
        <a href="/shop" class="cart-continue__link">← Continue Shopping</a>
      </div>
    </div>
    <div class="cart-drawer__footer" id="cartFooter" style="display:none">
      <div class="cart-subtotal">
        <span>Subtotal</span>
        <span id="cartSubtotal">$0</span>
      </div>
      <p class="cart-shipping-note">Shipping calculated at checkout</p>
      <button class="btn btn--primary cart-checkout-btn" id="cartCheckoutBtn">Checkout</button>
    </div>
  </aside>

  <style is:global>
    @import '../styles/global.css';
  </style>

  <style>
    /* ---- Header ---- */
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(248, 247, 245, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }

    .logo-name {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--charcoal);
    }

    .logo-sig {
      height: 32px;
      width: auto;
      display: block;
    }

    .main-nav {
      display: flex;
      gap: 2.5rem;
    }

    .main-nav a {
      font-family: var(--font-body);
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--stone);
      transition: color 0.2s;
      position: relative;
    }

    .main-nav a:hover,
    .main-nav a.active {
      color: var(--charcoal);
    }

    .main-nav a.active::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      right: 0;
      height: 1.5px;
      background: var(--teal);
    }

    .cart-btn {
      position: relative; display: flex; align-items: center; justify-content: center;
      color: var(--charcoal); transition: color 0.2s; margin-left: 0.5rem;
    }
    .cart-btn:hover { color: var(--teal); }
    .cart-count {
      position: absolute; top: -6px; right: -8px;
      font-family: var(--font-body); font-size: 0.55rem; font-weight: 700;
      background: var(--teal); color: var(--white);
      width: 16px; height: 16px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }

    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-toggle span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--charcoal);
      transition: 0.3s;
    }

    @media (max-width: 768px) {
      .main-nav {
        position: fixed;
        inset: 0;
        background: var(--white);
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
      }
      .main-nav.open {
        opacity: 1;
        pointer-events: all;
      }
      .main-nav a {
        font-size: 1.1rem;
      }
      .nav-toggle { display: flex; }
    }

    /* ---- Cart Drawer ---- */
    .cart-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 1999;
      opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
    }
    .cart-overlay.open { opacity: 1; pointer-events: auto; }

    .cart-drawer {
      position: fixed; top: 0; right: 0; bottom: 0; width: 420px; max-width: 92vw;
      background: #f8f7f5; z-index: 2000; display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: -8px 0 30px rgba(0,0,0,0.12);
    }
    .cart-drawer.open { transform: translateX(0); }

    .cart-drawer__header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 1.75rem; border-bottom: 1px solid #ededed;
      flex-shrink: 0;
    }
    .cart-drawer__header h3 {
      font-family: var(--font-display); font-size: 1.15rem; font-weight: 400;
      margin: 0; color: #1e1e1e; letter-spacing: -0.01em;
    }
    .cart-header-count {
      font-family: var(--font-body); font-size: 0.7rem; font-weight: 400;
      color: #6b6b6b;
    }
    .cart-drawer__close {
      background: none; border: none; cursor: pointer; color: #6b6b6b;
      width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
      border-radius: 50%; transition: all 0.2s;
    }
    .cart-drawer__close:hover { background: #ededed; color: #1e1e1e; }

    .cart-drawer__body { flex: 1; overflow-y: auto; padding: 1.5rem 1.75rem; }

    .cart-empty {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 4rem 1rem; text-align: center; min-height: 300px;
    }
    .cart-empty__icon { font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.3; }
    .cart-empty p { color: #6b6b6b; margin-bottom: 1.5rem; font-size: 0.9rem; }

    .cart-items { display: flex; flex-direction: column; gap: 0; }

    .cart-item {
      display: grid; grid-template-columns: 72px 1fr; gap: 1rem;
      padding: 1.25rem 0; border-bottom: 1px solid #ededed;
    }
    .cart-item:first-child { padding-top: 0; }

    .cart-item__img {
      width: 72px; height: 90px; object-fit: cover; border: 1px solid #ededed;
    }

    .cart-item__info {
      display: flex; flex-direction: column; justify-content: space-between;
      min-height: 90px;
    }
    .cart-item__top { display: flex; flex-direction: column; gap: 0.15rem; }
    .cart-item__title {
      font-family: var(--font-display); font-size: 0.95rem; font-weight: 400;
      color: #1e1e1e; line-height: 1.3;
    }
    .cart-item__detail {
      font-family: var(--font-body); font-size: 0.68rem; color: #6b6b6b;
      letter-spacing: 0.04em;
    }

    .cart-item__bottom {
      display: flex; align-items: center; justify-content: space-between;
    }
    .cart-item__qty {
      display: flex; align-items: center; gap: 0; border: 1px solid #d4d4d4;
    }
    .cart-item__qty-btn {
      width: 28px; height: 28px; background: none; border: none;
      cursor: pointer; font-size: 0.85rem; color: #1e1e1e;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .cart-item__qty-btn:hover { background: #ededed; }
    .cart-item__qty-val {
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      font-family: var(--font-body); font-size: 0.75rem; font-weight: 600;
      color: #1e1e1e; border-left: 1px solid #d4d4d4; border-right: 1px solid #d4d4d4;
    }
    .cart-item__price {
      font-family: var(--font-display); font-size: 0.95rem; color: #1e1e1e;
    }
    .cart-item__remove {
      background: none; border: none; font-size: 0.62rem; color: #a8a8a8;
      cursor: pointer; text-decoration: underline; padding: 0;
      font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;
      transition: color 0.15s;
    }
    .cart-item__remove:hover { color: #1e1e1e; }

    .cart-drawer__footer {
      padding: 1.25rem 1.75rem 1.75rem; border-top: 1px solid #ededed;
      background: #f8f7f5; flex-shrink: 0;
    }
    .cart-subtotal {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 0.35rem;
    }
    .cart-subtotal span:first-child {
      font-family: var(--font-body); font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase; color: #6b6b6b;
    }
    .cart-subtotal span:last-child {
      font-family: var(--font-display); font-size: 1.25rem; color: #1e1e1e;
    }
    .cart-shipping-note {
      font-size: 0.68rem; color: #a8a8a8; margin-bottom: 1.25rem;
    }
    .cart-checkout-btn {
      width: 100%; justify-content: center; font-size: 0.8rem; padding: 1rem 2rem;
      letter-spacing: 0.12em;
    }
    .cart-checkout-btn:disabled {
      opacity: 0.6; cursor: not-allowed;
    }

    .cart-continue { padding-top: 1.25rem; text-align: center; }
    .cart-continue__link {
      font-family: var(--font-body); font-size: 0.72rem; color: #5a8f8b;
      text-decoration: underline; text-underline-offset: 3px;
      letter-spacing: 0.03em; transition: color 0.15s;
    }
    .cart-continue__link:hover { color: #1e1e1e; }

    /* ---- Footer ---- */
    .site-footer {
      padding: var(--space-xl) 0 var(--space-md);
    }

    .footer-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-lg);
    }

    .footer-brand .logo-name {
      color: var(--white);
      display: block;
      margin-bottom: 0.75rem;
    }

    .footer-brand p {
      font-size: 0.85rem;
      color: var(--fog);
    }

    .footer-links {
      display: flex;
      gap: var(--space-lg);
      justify-self: end;
    }

    .footer-col {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer-col h4 {
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fog);
      margin-bottom: 0.5rem;
    }

    .footer-col a {
      font-size: 0.9rem;
      color: var(--mist);
      transition: color 0.2s;
    }

    .footer-col a:hover { color: var(--teal); }

    .footer-bottom {
      grid-column: 1 / -1;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: var(--space-md);
      margin-top: var(--space-md);
    }

    .footer-bottom p {
      font-size: 0.75rem;
      color: var(--stone);
    }

    @media (max-width: 768px) {
      .footer-inner { grid-template-columns: 1fr; }
      .footer-links { justify-self: start; }
    }
  </style>

  <script>
    // Nav toggle
    const toggle = document.getElementById('navToggle');
    const nav = document.getElementById('mainNav');
    toggle?.addEventListener('click', () => nav?.classList.toggle('open'));

    // ======== CART ========
    const CART_KEY = 'ennen_cart';

    function getCart(): any[] {
      try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; }
    }
    function saveCart(cart: any[]) {
      localStorage.setItem(CART_KEY, JSON.stringify(cart));
      updateCartUI();
    }
    function addToCart(item: any) {
      const cart = getCart();
      const key = `${item.slug}-${item.format}-${item.size || ''}-${item.colorway || ''}`;
      const existing = cart.find((c: any) => `${c.slug}-${c.format}-${c.size || ''}-${c.colorway || ''}` === key);
      if (existing) {
        existing.quantity += 1;
      } else {
        cart.push({ ...item, quantity: 1, key });
      }
      saveCart(cart);
      openCart();
    }
    function removeFromCart(key: string) {
      const cart = getCart().filter((c: any) => c.key !== key);
      saveCart(cart);
    }
    function clearCart() { saveCart([]); }

    // UI
    function updateCartUI() {
      const cart = getCart();
      const count = cart.reduce((sum: number, c: any) => sum + c.quantity, 0);
      const countEl = document.getElementById('cartCount');
      const headerCountEl = document.getElementById('cartHeaderCount');
      const continueEl = document.getElementById('cartContinue');
      if (countEl) {
        countEl.textContent = String(count);
        countEl.style.display = count > 0 ? 'flex' : 'none';
      }
      if (headerCountEl) {
        headerCountEl.textContent = count > 0 ? `(${count})` : '';
      }
      if (continueEl) {
        continueEl.style.display = count > 0 ? '' : 'none';
      }
      renderCartItems();
    }

    function renderCartItems() {
      const cart = getCart();
      const itemsEl = document.getElementById('cartItems');
      const emptyEl = document.getElementById('cartEmpty');
      const footerEl = document.getElementById('cartFooter');
      const subtotalEl = document.getElementById('cartSubtotal');
      if (!itemsEl) return;

      if (cart.length === 0) {
        itemsEl.innerHTML = '';
        if (emptyEl) emptyEl.style.display = '';
        if (footerEl) footerEl.style.display = 'none';
        return;
      }

      if (emptyEl) emptyEl.style.display = 'none';
      if (footerEl) footerEl.style.display = '';

      const subtotal = cart.reduce((sum: number, c: any) => sum + c.price * c.quantity, 0);
      if (subtotalEl) subtotalEl.textContent = `$${subtotal}`;

      itemsEl.innerHTML = cart.map((item: any) => {
        const detail = [item.formatLabel, item.size, item.colorway].filter(Boolean).join(' · ');
        return `
          <div class="cart-item">
            <img src="${item.image}" alt="${item.title}" class="cart-item__img" />
            <div class="cart-item__info">
              <div class="cart-item__top">
                <span class="cart-item__title">${item.title}</span>
                <span class="cart-item__detail">${detail}</span>
              </div>
              <div class="cart-item__bottom">
                <div class="cart-item__qty">
                  <button class="cart-item__qty-btn" data-cart-key="${item.key}" data-action="dec">−</button>
                  <span class="cart-item__qty-val">${item.quantity}</span>
                  <button class="cart-item__qty-btn" data-cart-key="${item.key}" data-action="inc">+</button>
                </div>
                <span class="cart-item__price">$${item.price * item.quantity}</span>
              </div>
              <button class="cart-item__remove" data-cart-key="${item.key}">Remove</button>
            </div>
          </div>
        `;
      }).join('');

      // Bind remove buttons
      itemsEl.querySelectorAll('.cart-item__remove').forEach((btn) => {
        btn.addEventListener('click', () => {
          removeFromCart(btn.getAttribute('data-cart-key') || '');
        });
      });

      // Bind quantity buttons
      itemsEl.querySelectorAll('.cart-item__qty-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = btn.getAttribute('data-cart-key') || '';
          const action = btn.getAttribute('data-action');
          const cart = getCart();
          const item = cart.find((c: any) => c.key === key);
          if (!item) return;
          if (action === 'inc') {
            item.quantity += 1;
          } else if (action === 'dec') {
            item.quantity -= 1;
            if (item.quantity <= 0) {
              removeFromCart(key);
              return;
            }
          }
          saveCart(cart);
        });
      });
    }

    function openCart() {
      document.getElementById('cartDrawer')?.classList.add('open');
      document.getElementById('cartOverlay')?.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeCart() {
      document.getElementById('cartDrawer')?.classList.remove('open');
      document.getElementById('cartOverlay')?.classList.remove('open');
      document.body.style.overflow = '';
    }

    // Bind cart open/close
    document.getElementById('cartBtn')?.addEventListener('click', (e) => {
      e.preventDefault();
      openCart();
    });
    document.getElementById('cartClose')?.addEventListener('click', closeCart);
    document.getElementById('cartOverlay')?.addEventListener('click', closeCart);

    // Checkout
    document.getElementById('cartCheckoutBtn')?.addEventListener('click', async () => {
      const cart = getCart();
      if (cart.length === 0) return;
      const btn = document.getElementById('cartCheckoutBtn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Processing…'; }
      try {
        const res = await fetch('/api/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: cart.map((c: any) => ({
            slug: c.slug,
            format: c.format,
            quantity: c.quantity,
            size: c.size || undefined,
            colorway: c.colorway || undefined,
          }))})
        });
        const data = await res.json();
        if (data.url) {
          clearCart();
          window.location.href = data.url;
        } else {
          throw new Error(data.error || 'Checkout failed');
        }
      } catch (err) {
        console.error('Checkout error:', err);
        alert('Something went wrong. Please try again.');
        if (btn) { btn.disabled = false; btn.textContent = 'Checkout'; }
      }
    });

    // Expose addToCart globally for PDP
    (window as any).ennenCart = { addToCart, openCart, getCart };

    // Init
    updateCartUI();
  </script>

</body>
</html>
