---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Order Confirmed — Mikey Ennen">

  <section class="success-page">
    <div class="container container--narrow success-content">
      <span class="label">Order Confirmed</span>
      <h1>Thank You</h1>
      <p>Your piece is on its way. You'll receive a confirmation email from Stripe shortly.</p>
      <p>Prints and tees are made to order and typically arrive in 7–12 days.</p>
      <a href="/shop" class="btn btn--primary" style="margin-top: 2rem;">Continue Shopping</a>
    </div>
  </section>

</BaseLayout>

<script>
  // Clear cart after successful checkout
  localStorage.removeItem('ennen_cart');
  const countEl = document.getElementById('cartCount');
  if (countEl) countEl.style.display = 'none';
  const headerCountEl = document.getElementById('cartHeaderCount');
  if (headerCountEl) headerCountEl.textContent = '';
</script>

<style>
  .success-page {
    padding-top: calc(72px + var(--space-xl));
    padding-bottom: var(--space-xl);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .success-content {
    text-align: center;
  }

  .success-content p {
    max-width: none;
    margin: 0 auto;
    margin-top: 1rem;
  }

  .success-page h1 {
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }
</style>
