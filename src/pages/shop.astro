---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const originals = products.filter((p: any) => p.formats.some((f: any) => f.type === 'original'));
const prints = products.filter((p: any) => p.formats.some((f: any) => f.type === 'print'));
const tees = products.filter((p: any) => p.formats.some((f: any) => f.type === 'tee'));
---

<BaseLayout title="Shop — Mikey Ennen">

  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/art/prints/nautical-color-hero.jpg" alt="Mikey Ennen artwork" class="page-hero__img" />
    </div>
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <span class="label">Shop</span>
      <h1>The Collection</h1>
      <p>Original artwork, hand-pulled prints, and wearable art. Every piece rooted in Pacific Northwest nature.</p>
    </div>
  </section>

  <!-- ORIGINALS -->
  <section class="section" id="originals">
    <div class="container">
      <h2>Originals</h2>
      <p style="margin-bottom: 2.5rem;">One-of-a-kind pieces. Charcoal, ink, and woodcut on paper and panel.</p>
      <div class="grid-3">
        {originals.map((product: any) => {
          const orig = product.formats.find((f: any) => f.type === 'original');
          return (
            <ProductCard
              title={product.title}
              price={`$${orig.price}`}
              image={`${product.image}-card.jpg`}
              category={product.medium}
              href={`/shop/${product.slug}`}
              soldOut={!orig.available}
            />
          );
        })}
      </div>
    </div>
  </section>

  <!-- PRINTS -->
  <section class="section" id="prints" style="background: var(--cloud);">
    <div class="container">
      <h2>Printed Art</h2>
      <p style="margin-bottom: 2.5rem;">Hand-pulled woodcut prints and archival giclées. Signed and numbered.</p>
      <div class="grid-3">
        {prints.map((product: any) => {
          const print = product.formats.find((f: any) => f.type === 'print');
          return (
            <ProductCard
              title={product.title}
              price={`$${print.price}`}
              image={`${product.image}-card.jpg`}
              category={product.color || 'Print'}
              href={`/shop/${product.slug}`}
            />
          );
        })}
      </div>
    </div>
  </section>

  <!-- APPAREL -->
  <section class="section" id="apparel">
    <div class="container">
      <h2>T-Shirts</h2>
      <p style="margin-bottom: 2.5rem;">Premium blanks. Mike's artwork printed direct-to-garment. S–2XL.</p>
      <div class="grid-3">
        {tees.map((product: any) => {
          const tee = product.formats.find((f: any) => f.type === 'tee');
          return (
            <ProductCard
              title={`${product.title} Tee`}
              price={`$${tee.price}`}
              image={`${product.image}-card.jpg`}
              category="Unisex"
              href={`/shop/${product.slug}`}
            />
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding: calc(72px + var(--space-xl)) 0 var(--space-lg);
    min-height: 40vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--black);
  }

  .page-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.8) 0%, rgba(10,10,10,0.2) 60%);
  }

  .page-hero__content {
    position: relative;
    z-index: 2;
    color: var(--white);
  }

  .page-hero__content h1 {
    margin-top: 0.5rem;
    font-weight: 300;
  }

  .page-hero__content p {
    color: var(--fog);
    margin-top: 1rem;
  }
</style>
