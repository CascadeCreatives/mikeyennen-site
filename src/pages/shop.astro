---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const positionMap: Record<string, string> = {
  'gravity-rasta':  'center top',
  'lbs-blue-1':     'center top',
  'waterfall-bw':   'center top',
};

const badgeMap: Record<string, string> = {
  'ravens-dark-blue-hr': 'Popular',
  'kraken': 'Popular',
  'sasquatch-green': 'Popular',
  'baker-trees-bw': 'Bestseller',
  'mt-shuksan-trees': 'Bestseller',
  'northwest-islands': 'New',
  'jones-peaks': 'New',
  'baker-willows': 'New',
};
---

<BaseLayout
  title="Shop — Mikey Ennen"
  description="Woodcut prints and wearable art by Mikey Ennen. Rooted in the Pacific Northwest."
  ogImage="/art/prints/sasquatch-green-hero.jpg"
>

  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/art/prints/sasquatch-green-hero.jpg" alt="Sasquatch — Mikey Ennen print" class="page-hero__img" />
    </div>
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <span class="label">Shop</span>
      <h1>The Collection</h1>
      <p>Woodcut prints and wearable art — printed on demand. Every piece rooted in Pacific Northwest nature.</p>
    </div>
  </section>

  <section class="section" id="collection">
    <div class="container">
      <div class="grid-3">
        {products.map((product: any) => {
          const avail = product.formats.filter((f: any) => f.available);
          const lowestPrice = avail.length ? Math.min(...avail.map((f: any) => f.price)) : 0;
          const priceLabel = avail.length > 1 ? `From $${lowestPrice}` : `$${lowestPrice}`;
          const colorCount = product.colorways?.length || 0;
          const subtitle = colorCount > 1 ? `${colorCount} colorways` : 'Woodcut Print';
          return (
            <ProductCard
              title={product.title}
              price={priceLabel}
              image={`${product.image}-card.jpg`}
              category={subtitle}
              href={`/shop/${product.slug}`}
              badge={badgeMap[product.slug]}
              objectPosition={positionMap[product.slug] || 'center'}
            />
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding: calc(72px + var(--space-xl)) 0 var(--space-lg);
    min-height: 40vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .page-hero__bg { position: absolute; inset: 0; background: var(--black); }
  .page-hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; opacity: 0.45; }
  .page-hero__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,10,10,0.8) 0%, rgba(10,10,10,0.2) 60%); }
  .page-hero__content { position: relative; z-index: 2; color: var(--white); }
  .page-hero__content h1 { margin-top: 0.5rem; font-weight: 300; }
  .page-hero__content p { color: var(--fog); margin-top: 1rem; }
</style>
