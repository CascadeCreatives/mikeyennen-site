---
import BaseLayout from '../../layouts/BaseLayout.astro';
import products from '../../data/products.json';

export function getStaticPaths() {
  return products.map((product: any) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const availableFormats = product.formats.filter((f: any) => f.available);
---

<BaseLayout title={`${product.title} — Mikey Ennen`} description={product.description}>

  <section class="product-page">
    <div class="container product-grid">

      <!-- Image -->
      <div class="product-image">
        <img src={`${product.image}-card.jpg`} alt={product.title} />
      </div>

      <!-- Details -->
      <div class="product-details">
        <span class="label">{product.medium}</span>
        <h1>{product.title}</h1>
        <p class="product-description">{product.description}</p>

        <!-- Format Selector -->
        <div class="format-selector" id="formatSelector">
          {availableFormats.map((f: any, i: number) => (
            <button
              class:list={['format-btn', { active: i === 0 }]}
              data-format={f.type}
              data-price={f.price}
              data-detail={f.detail}
            >
              <span class="format-label">
                {f.type === 'tee' ? 'T-Shirt' : f.type === 'print' ? 'Print' : 'Original'}
              </span>
              <span class="format-price">${f.price}</span>
            </button>
          ))}
        </div>

        <p class="format-detail" id="formatDetail">{availableFormats[0]?.detail}</p>

        <button class="btn btn--primary buy-btn" id="buyBtn" data-slug={product.slug}>
          Buy Now
        </button>

        {product.color && (
          <p class="product-meta">Color: {product.color}</p>
        )}
      </div>
    </div>
  </section>

  <div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <p>Redirecting to checkout…</p>
  </div>

</BaseLayout>

<style>
  .product-page {
    padding-top: calc(72px + var(--space-lg));
    padding-bottom: var(--space-xl);
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .product-image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--cloud);
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-details {
    padding-top: var(--space-md);
  }

  .product-details h1 {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .product-description {
    margin-bottom: var(--space-md);
  }

  /* Format selector */
  .format-selector {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .format-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1rem 1.5rem;
    background: transparent;
    border: 1px solid var(--mist);
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-body);
    min-width: 100px;
  }

  .format-btn:hover {
    border-color: var(--charcoal);
  }

  .format-btn.active {
    border-color: var(--charcoal);
    background: var(--charcoal);
    color: var(--white);
  }

  .format-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .format-price {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 400;
  }

  .format-detail {
    font-size: 0.85rem;
    color: var(--stone);
    margin-bottom: var(--space-md);
    min-height: 1.5em;
  }

  .buy-btn {
    width: 100%;
    justify-content: center;
    margin-bottom: var(--space-sm);
    font-size: 0.85rem;
    padding: 1.1rem 2rem;
  }

  .product-meta {
    font-size: 0.8rem;
    color: var(--fog);
    margin-top: var(--space-sm);
  }

  /* Loading overlay */
  .loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(248, 247, 245, 0.95);
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
    z-index: 9999;
  }

  .loading-overlay.visible {
    display: flex;
  }

  .loading-spinner {
    width: 32px;
    height: 32px;
    border: 2px solid var(--mist);
    border-top-color: var(--charcoal);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  .loading-overlay p {
    font-size: 0.85rem;
    color: var(--stone);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>

<script>
  // Format selector
  const buttons = document.querySelectorAll('.format-btn');
  const detail = document.getElementById('formatDetail');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      if (detail) detail.textContent = btn.getAttribute('data-detail') || '';
    });
  });

  // Buy button
  const buyBtn = document.getElementById('buyBtn') as HTMLButtonElement;
  const overlay = document.getElementById('loadingOverlay');

  buyBtn?.addEventListener('click', async () => {
    const activeFormat = document.querySelector('.format-btn.active');
    if (!activeFormat) return;

    const slug = buyBtn.dataset.slug;
    const format = activeFormat.getAttribute('data-format');

    buyBtn.disabled = true;
    buyBtn.textContent = 'Processing…';
    overlay?.classList.add('visible');

    try {
      const res = await fetch('/api/create-checkout-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, format, quantity: 1 }),
      });

      const data = await res.json();

      if (data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Failed to create checkout session');
      }
    } catch (err: any) {
      console.error('Checkout error:', err);
      alert('Something went wrong. Please try again.');
      buyBtn.disabled = false;
      buyBtn.textContent = 'Buy Now';
      overlay?.classList.remove('visible');
    }
  });
</script>
